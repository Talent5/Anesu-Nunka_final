# Keep repository focused on source code and deployment config.
# Ignore document-style files and generated/system artifacts.

# Office/PDF documents
*.doc
*.docx
*.pdf
*.ppt
*.pptx

# Methodology/design writeups in markdown
Chapter_*.md

# Non-code artifacts (keep repo code-focused)
*.csv
*.ipynb
*.png
*.jpg
*.jpeg
*.log

# Temporary Office lock files
~$*

# Python artifacts
**/__pycache__/
*.pyc

# Node artifacts
frontend/node_modules/
frontend/dist/

# Prototype workspace (local-only)
Prototype/

# Local environment files
.env
backend/.env
frontend/.env

# Keep readme files tracked
!README.md
!**/README.md

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
